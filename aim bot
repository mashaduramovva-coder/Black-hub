-- =====================
--   WORLD EFFECTS FUNCTIONS
-- =====================
local function applyWorldSettings()
    if WORLD.fullbright then
        Lighting.Brightness = 2
        Lighting.Ambient = Color3.fromRGB(255, 255, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    else
        Lighting.Brightness = originalLighting.Brightness
        Lighting.Ambient = originalLighting.Ambient
        Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
    end
    
    if WORLD.customWorld then
        Lighting.ColorShift_Top = Color3.fromRGB(255, 0, 255)
        Lighting.ColorShift_Bottom = Color3.fromRGB(128, 0, 128)
        Lighting.FogColor = Color3.fromRGB(150, 0, 150)
        Lighting.FogEnd = 500
    else
        Lighting.ColorShift_Top = originalLighting.ColorShift_Top
        Lighting.ColorShift_Bottom = originalLighting.ColorShift_Bottom
        Lighting.FogColor = originalLighting.FogColor
        Lighting.FogEnd = originalLighting.FogEnd
    end
end

-- =====================
--   RAINBOW CROSSHAIR (Rotating Plus Shape)
-- =====================
local function setupCrosshair()
    if crosshairObj then
        crosshairObj:Destroy()
        crosshairObj = nil
    end
    
    if not WORLD.crosshair then return end
    
    crosshairObj = Instance.new("ScreenGui")
    crosshairObj.Name = "RainbowCrosshair"
    crosshairObj.IgnoreGuiInset = true
    crosshairObj.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    crosshairObj.Parent = LP.PlayerGui
    
    -- Main frame for crosshair
    local crossFrame = Instance.new("Frame", crosshairObj)
    crossFrame.Size = UDim2.new(0, 30, 0, 30)
    crossFrame.Position = UDim2.new(0.5, -15, 0.5, -15)
    crossFrame.BackgroundTransparency = 1
    crossFrame.ClipsDescendants = false
    
    -- Horizontal bar (plus shape)
    local hBar = Instance.new("Frame", crossFrame)
    hBar.Size = UDim2.new(1, 0, 0, 3)
    hBar.Position = UDim2.new(0, 0, 0.5, -1.5)
    hBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    hBar.BorderSizePixel = 0
    Instance.new("UICorner", hBar).CornerRadius = UDim.new(1, 0)
    
    -- Vertical bar (plus shape)
    local vBar = Instance.new("Frame", crossFrame)
    vBar.Size = UDim2.new(0, 3, 1, 0)
    vBar.Position = UDim2.new(0.5, -1.5, 0, 0)
    vBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    vBar.BorderSizePixel = 0
    Instance.new("UICorner", vBar).CornerRadius = UDim.new(1, 0)
    
    -- Rotation and color animation
    local hue = 0
    local rotationSpeed = 180 -- degrees per second
    
    RunService.RenderStepped:Connect(function(dt)
        if not WORLD.crosshair or not crossframe then return end
        
        -- Rotate the crosshair
        crossAngle = crossAngle + (rotationSpeed * dt)
        crossFrame.Rotation = crossAngle % 360
        
        -- Cycle colors (rainbow effect)
        hue = (hue + dt * 1.5) % 1
        local color = Color3.fromHSV(hue, 1, 1)
        hBar.BackgroundColor3 = color
        vBar.BackgroundColor3 = color
    end)
    
    crossframe = crossFrame
    crossAngle = 0
end

