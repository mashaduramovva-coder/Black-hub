    btn.Text = get() and "ON" or "OFF"; btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.TextSize = 10; btn.Font = Enum.Font.GothamBold; btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,9)
    btn.MouseButton1Click:Connect(function()
        set(not get())
        btn.Text = get() and "ON" or "OFF"
        TweenSvc:Create(btn, TweenInfo.new(0.12), {
            BackgroundColor3 = get() and Color3.fromRGB(50,170,50) or Color3.fromRGB(140,40,40)
        }):Play()
        -- Apply world settings when toggled
        if label == "FullBright" or label == "Custom World" then
            applyWorldSettings()
        end
    end)
end

local function mkSlider(parent, label, get, set, mn, mx, isInt)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1,-10,0,45); f.BackgroundColor3 = Color3.fromRGB(28,28,45)
    f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0,6)
    local lbl = Instance.new("TextLabel", f)
    lbl.Size = UDim2.new(1,-50,0,18); lbl.Position = UDim2.new(0,8,0,2)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(190,190,215); lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local valLbl = Instance.new("TextLabel", f)
    valLbl.Size = UDim2.new(0,40,0,18); valLbl.Position = UDim2.new(1,-45,0,2)
    valLbl.BackgroundTransparency = 1; valLbl.Text = tostring(get())
    valLbl.TextColor3 = Color3.fromRGB(100,200,255); valLbl.TextSize = 12
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextXAlignment = Enum.TextXAlignment.Right
    local bg = Instance.new("Frame", f)
    bg.Size = UDim2.new(1,-16,0,6); bg.Position = UDim2.new(0,8,0,30)
    bg.BackgroundColor3 = Color3.fromRGB(45,45,65); bg.BorderSizePixel = 0
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1,0)
    local pct = math.clamp((get()-mn)/(mx-mn),0,1)
    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new(pct,0,1,0); fill.BackgroundColor3 = Color3.fromRGB(70,70,200)
    fill.BorderSizePixel = 0; Instance.new("UICorner",fill).CornerRadius = UDim.new(1,0)
    local knob = Instance.new("TextButton", bg)
    knob.Size = UDim2.new(0,14,0,14); knob.Position = UDim2.new(pct,-7,0.5,-7)
    knob.BackgroundColor3 = Color3.fromRGB(110,110,255); knob.Text = ""
    knob.BorderSizePixel = 0; knob.ZIndex = 5
    Instance.new("UICorner",knob).CornerRadius = UDim.new(1,0)
    local drag = false
    knob.MouseButton1Down:Connect(function() drag = true end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    UIS.InputChanged:Connect(function(i)
        if not drag or i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local p = math.clamp((UIS:GetMouseLocation().X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
