        ob.Text = opt; ob.TextColor3 = Color3.fromRGB(200,200,200); ob.TextSize = 11
        ob.Font = Enum.Font.Gotham; ob.BorderSizePixel = 0; ob.ZIndex = 21
        ob.MouseButton1Click:Connect(function() set(opt); dbtn.Text = opt; menu.Visible = false end)
    end
    dbtn.MouseButton1Click:Connect(function()
        menu.Visible = not menu.Visible
        if menu.Visible then
            local ap = dbtn.AbsolutePosition
            menu.Position = UDim2.new(0, ap.X, 0, ap.Y + dbtn.AbsoluteSize.Y + 2)
            menu.Size = UDim2.new(0, dbtn.AbsoluteSize.X, 0, #opts*26)
        end
    end)
    UIS.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        task.wait()
        if not menu.Visible then return end
        local mp = UIS:GetMouseLocation(); local ap = menu.AbsolutePosition; local as = menu.AbsoluteSize
        if mp.X<ap.X or mp.X>ap.X+as.X or mp.Y<ap.Y or mp.Y>ap.Y+as.Y then menu.Visible = false end
    end)
end

